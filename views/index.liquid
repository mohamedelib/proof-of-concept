{% render 'partials/head.liquid', title: 'Dashboard' %}

<body>
  {% comment %} header {% endcomment %}
  <header class="upperheader">
    <picture>
      <source srcset="/assets/tweakers.avif" type="image/avif">
      <source srcset="/assets/tweakers.webp" type="image/webp">
      <img src="/assets/tweakers.jpg" width="{{ 180 }}" height="{{ 50 }}" alt="{{ Tweakers }}" fetchpriority="high">
    </picture>
    <button class="hamburger" popovertarget="hamburger">
      <img src="/assets/burger-menu.svg" width="50" height="40" alt="menu">
    </button>
    <nav id="hamburger" popover>
      <button type="button" popovertarget="hamburger" aria-label="menu sluiten">✕</button>
      <ol>
        <li><a href="#">Overzicht</a></li>
        <li><a href="#">Topics</a></li>
        <li><a href="#">Gebruikers</a></li>
        <li><a href="#">Meldingen</a></li>
      </ol>
    </nav>
  </header>

  {% comment %} einde header {% endcomment %}
  <main>
    <h1>Welkom Communitymanager!</h1>
    <div class="maincontainer">
      <section class="active-topics card">
        <h2>Meest actieve topics</h2>
        <table>
          {% for item in items %}
          <tr>
            <td>{{ forloop.index }}</td>
            <td><a href="{{ item.link }}">{{ item.title }}</a></td>
            <td class="number">{{ item.replies }}</td>
          </tr>
          {% endfor %}
        </table>
      </section>
      <section class="top-gebruikers card">
        <h2>Top gebruikers</h2>
        <ul>
          <li>
            <article>
              <h3>Kees</h3>
              <p>lid sinds 2012</p>
            </article>
          </li>
          <li>
            <article>
              <h3>Piet</h3>
              <p>lid sinds 2026</p>
            </article>
          </li>
          <li>
            <article>
              <h3>Haas</h3>
              <p>lid sinds 2018</p>
            </article>
          </li>
          <li>
            <article>
              <h3>Gerda</h3>
              <p>lid sinds 2021</p>
            </article>
          </li>
          <li>
            <article>
              <h3>Tom</h3>
              <p>lid sinds 2008</p>
            </article>
          </li>
        </ul>
      </section>
      <section class="nieuwe-posts card">
        <h2>Nieuwe posts vandaag</h2>
        <p>1284</p>
      </section>

      <section class="active-cats card">
        <h2>Most actieve categorieën</h2>
        <table>
          {% for categorie in categorieen %}
          <tr>
            <td>{{ forloop.index }}</td>
            <td><a href="{{ categorie.link }}">{{ categorie.naam }} </a></td>
            <td class="number">{{ categorie.totaalReacties }}</td>
          </tr>
          {% endfor %}
        </table>
      </section>

      <section class="activiteit card">
        <h2>Activiteit</h2>
        <p>Posts * 7dagen</p>
      </section>
      <section class="meldingen card-small">
        <h2>Meldingen open</h2>
        <p>47</p>
      </section>
      <section class="nieuweleden card-small">
        <h2>Nieuwe leden(24u)</h2>
        <p>63</p>
      </section>
    </div>
  </main>
</body>