{% render 'partials/head.liquid', title: 'Dashboard' %}


{% render 'partials/header.liquid', activePage: activePage %}

{% comment %} einde header {% endcomment %}


<main class="dashboard">
  <h1>Welkom {{ name }}</h1>
  <div class="maincontainer">

    {% comment %} Actieve topics {% endcomment %}
    <section class="active-topics card">
      <h2>Meest actieve topics</h2>
      <table>
        {% for item in items %}
        <tr>
          <td>{{ forloop.index }}</td>
          <td>
            <a href="{{ item.link }}">{{ item.title }}</a>
          </td>
          <td class="number">{{ item.replies }}</td>
        </tr>
        {% endfor %}
      </table>
    </section>
    <section class="top-users card">

      {% comment %} Top gebruikers {% endcomment %}
      <h2>Top gebruikers</h2>
      {% for user in users %}
      <table>
        <tr>
          <td>
            <img src="https://tweakers.net/identicon/{{ user.forum_id }}" width="16" height="16" alt="">
          </td>
          <td>{{ user.username }}</td>
          <td class="number">{{ user.number_of_posts }}</td>
        </tr>
      </table>
      {% endfor %}
    </section>
    <section class="new-posts card">
      <h2>Nieuwe posts vandaag</h2>
      <p>1284</p>
    </section>

    {% comment %} Actieve categorien {% endcomment %}
    <section class="active-cats card">
      <h2>Meest actieve categorieën</h2>
      <table>
        {% for categorie in categorieen %}
        <tr>
          <td>{{ forloop.index }}</td>
          <td>
            <a href="{{ categorie.link }}">{{ categorie.naam }} </a>
          </td>
          <td class="number">{{ categorie.totaalReacties }}</td>
        </tr>
        {% endfor %}
      </table>
    </section>
    {% comment %} Activityy card {% endcomment %}
    <section class="activity card">
      <h2>Activiteit</h2>
      <p>Posts * 7dagen</p>
    </section>

    {% comment %} Meldingen {% endcomment %}
    <section class="messages card">
      <h2>Meldingen open</h2>
      <p>47</p>
    </section>

    {% comment %} Nieuwe gebruikers {% endcomment %}
    <section class="new-users card">
      <h2>Nieuwe leden(24u)</h2>
      <p>63</p>
    </section>
  </div>
</main>
</body>