{% render 'partials/head.liquid', title: 'Login' %}

<header class="upperheader">
  <picture>
    <source srcset="/assets/logo-white.avif" type="image/avif">
    <source srcset="/assets/logo-white.webp" type="image/webp">
    <img
      class="logo"
      src="/assets/logo-white.png"
      width="{{ 190 }}"
      height="{{ 50 }}"
      alt=" Tweakers"
      fetchpriority="high"
    >
  </picture>
</header>
<main class="loginpage">
  <aside class="login-hero">
    <h2>Tweakers Dashboard</h2>
    <p>Beheer je community op één plek.</p>
     <p>bla bla bla bla bla bla bla bla bla bla</p>
      <p>bla bla bla bla bla bla bla bla</p>
       <p>bla bla bla bla bla bla </p>
        <p>bla bla bla bla bla </p>
  </aside>
  <section class="login">
  <section class="welcometext">
    <h1>Welkom terug!</h1>
    <p>Gelieve uw gegevens hieronder in te vullen.</p>
  </section>
  <form method="POST" class="login-form">
    <div class="name-login">
      <label for="name">Gebruikersnaam</label>
      <input type="text" name="name" id="name" required>
    </div>
    <div class="password-login">
      <label for="password">Wachtwoord</label>
      <input type="password" name="password" id="password" required>
    </div>
    <div class="form-example ">
      <input type="submit" value="Inloggen">
    </div>
    </section>
  </form>
</main>



