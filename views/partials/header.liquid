{% comment %} header {% endcomment %}
<header class="upperheader">
  <picture>
    <source srcset="/assets/logo-white.avif" type="image/avif">
    <img class="logo" src="/assets/logo-white.png" width="190" height="50" alt="Tweakers" fetchpriority="high">
  </picture>

  <nav class="desktop-nav">
    <ul>
      <li>
        <a
          href="dashboard"
          {% if activePage == 'dashboard' %}
            class="active"
          {% endif %}
          >Dashboard</a
        >
      </li>
      <li><a href="#">Topics</a></li>
      <li>
        <a
          href="gebruikers"
          {% if activePage == 'gebruikers' %}
            class="active"
          {% endif %}
          >Gebruikers</a
        >
      </li>
      <li><a href="#">Meldingen</a></li>
    </ul>
  </nav>

  <p class="live-section">
    <span class="live-dot"></span>
    Status: Live
  </p>

  <button class="hamburger" popovertarget="hamburger">
    <img src="/assets/burger-menu.svg" width="50" height="40" alt="menu">
  </button>
  <nav id="hamburger" popover>
    <button type="button" popovertarget="hamburger" aria-label="Sluit menu">✕</button>
    <ol>
      <li><a href="dashboard">Dashboard</a></li>
      <li><a href="#">Topics</a></li>
      <li><a href="gebruikers">Gebruikers</a></li>
      <li><a href="#">Meldingen</a></li>
    </ol>
  </nav>
</header>
